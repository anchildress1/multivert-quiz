{
  "ci": {
    "collect": {
      "url": ["http://127.0.0.1:4173/"],
      "startServerCommand": "pnpm preview --host 127.0.0.1 --port 4173",
      "startServerReadyPattern": "Local:.*4173",
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "_comment": "Mobile gate: performance is a hard 0.95 minimum (error). Other categories track 100 as warn-only — they regress informationally without blocking. Desktop (.lighthouserc.desktop.json) is the hard 100/100/100/100 gate.",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["warn", { "minScore": 1 }],
        "categories:best-practices": ["warn", { "minScore": 1 }],
        "categories:seo": ["warn", { "minScore": 1 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
