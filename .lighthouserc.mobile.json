{
  "ci": {
    "collect": {
      "url": ["http://127.0.0.1:4173/"],
      "startServerCommand": "pnpm preview --host 127.0.0.1 --port 4173",
      "startServerReadyPattern": "Local:.*4173",
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "_comment": "Mobile is reports-only: scores are uploaded to temporary-public-storage on every run, but assertions are warn-level so a 92 mobile perf does not block CI. Desktop (.lighthouserc.desktop.json) is the hard 100/100/100/100 gate.",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 1 }],
        "categories:accessibility": ["warn", { "minScore": 1 }],
        "categories:best-practices": ["warn", { "minScore": 1 }],
        "categories:seo": ["warn", { "minScore": 1 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
